{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://metiers-quebec.org/feed-schema.json",
  "title": "Emploi Québec Feed – JSON Feed 1.1 avec extensions",
  "description": "Schéma du flux d'agrégation des sources d'emploi, métiers et formation au Québec. Étend JSON Feed 1.1 avec l'extension _quebec_emploi.",
  "type": "object",
  "required": ["version", "title", "items"],
  "properties": {
    "version": {
      "type": "string",
      "const": "https://jsonfeed.org/version/1.1",
      "description": "Version du format JSON Feed"
    },
    "title": {
      "type": "string",
      "description": "Titre du flux"
    },
    "home_page_url": {
      "type": "string",
      "format": "uri",
      "description": "URL de la page d'accueil du site"
    },
    "feed_url": {
      "type": "string",
      "format": "uri",
      "description": "URL auto-référentielle du flux"
    },
    "description": {
      "type": "string",
      "description": "Description du flux"
    },
    "language": {
      "type": "string",
      "const": "fr-CA",
      "description": "Langue principale du flux (BCP 47)"
    },
    "favicon": {
      "type": "string",
      "format": "uri",
      "description": "URL du favicon"
    },
    "authors": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/author"
      }
    },
    "items": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/item"
      }
    }
  },
  "$defs": {
    "author": {
      "type": "object",
      "properties": {
        "name": { "type": "string" },
        "url": { "type": "string", "format": "uri" },
        "avatar": { "type": "string", "format": "uri" }
      }
    },
    "item": {
      "type": "object",
      "required": ["id", "title"],
      "properties": {
        "id": {
          "type": "string",
          "description": "Identifiant unique et permanent de l'item (URL stable)"
        },
        "url": {
          "type": "string",
          "format": "uri",
          "description": "URL de la ressource source"
        },
        "external_url": {
          "type": "string",
          "format": "uri"
        },
        "title": {
          "type": "string",
          "description": "Titre de l'item"
        },
        "content_html": {
          "type": "string",
          "description": "Contenu en HTML"
        },
        "content_text": {
          "type": "string",
          "description": "Contenu en texte brut"
        },
        "summary": {
          "type": "string",
          "description": "Résumé court"
        },
        "image": {
          "type": "string",
          "format": "uri"
        },
        "banner_image": {
          "type": "string",
          "format": "uri"
        },
        "date_published": {
          "type": "string",
          "format": "date-time",
          "description": "Date de publication (RFC 3339)"
        },
        "date_modified": {
          "type": "string",
          "format": "date-time",
          "description": "Date de dernière modification (RFC 3339)"
        },
        "authors": {
          "type": "array",
          "items": { "$ref": "#/$defs/author" }
        },
        "tags": {
          "type": "array",
          "items": { "type": "string" },
          "description": "Tags de classification (emploi, formation, metiers, statistiques, etc.)"
        },
        "language": {
          "type": "string"
        },
        "_quebec_emploi": {
          "$ref": "#/$defs/quebec-emploi-extension",
          "description": "Extension personnalisée pour les métadonnées emploi Québec"
        }
      }
    },
    "quebec-emploi-extension": {
      "type": "object",
      "required": ["source_id", "source_nom", "categorie"],
      "properties": {
        "about": {
          "type": "string",
          "const": "https://metiers-quebec.org/sources-emploi-quebec.json",
          "description": "Référence vers le catalogue des sources"
        },
        "source_id": {
          "type": "integer",
          "minimum": 1,
          "maximum": 15,
          "description": "ID de la source dans sources-emploi-quebec.json"
        },
        "source_nom": {
          "type": "string",
          "description": "Nom court de la source"
        },
        "source_url": {
          "type": "string",
          "format": "uri",
          "description": "URL du site source"
        },
        "type_source": {
          "type": "string",
          "enum": [
            "gouvernement_provincial",
            "organisme_institutionnel",
            "donnees_ouvertes",
            "federal"
          ],
          "description": "Type d'organisme source"
        },
        "categorie": {
          "type": "string",
          "enum": [
            "emploi",
            "metiers",
            "formation",
            "statistiques",
            "marche_du_travail",
            "donnees_ouvertes",
            "classification"
          ],
          "description": "Catégorie thématique du contenu"
        },
        "region": {
          "type": "string",
          "description": "Région géographique visée"
        },
        "formats_disponibles": {
          "type": "array",
          "items": {
            "type": "string",
            "enum": ["HTML", "PDF", "CSV", "XLSX", "JSON", "XML", "SDMX", "API"]
          }
        },
        "api_disponible": {
          "type": "boolean",
          "description": "Indique si la source offre une API programmatique"
        },
        "derniere_mise_a_jour": {
          "type": "string",
          "format": "date-time"
        }
      }
    }
  }
}
