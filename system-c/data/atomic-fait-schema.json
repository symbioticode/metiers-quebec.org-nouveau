{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://metiers-quebec.org/data/atomic-fait-schema.json",
  "title": "Fiche atomique — kb008-bis",
  "description": "Schéma d'une fiche métier au format atomique (FAIT/GARDE/ORIGINE/CODE). Couche System C - Atomique, distincte du catalogue System C - Catalogue (feed-schema.json).",
  "type": "object",
  "required": ["code", "noms", "faits", "completude"],
  "properties": {
    "code": {
      "type": "string",
      "description": "Code CNP 2021, identifiant canonique du métier",
      "pattern": "^[0-9]{5}$"
    },
    "noms": {
      "type": "array",
      "items": { "type": "string" },
      "minItems": 1
    },
    "secteur": { "type": "string" },
    "faits": {
      "type": "array",
      "items": { "$ref": "#/$defs/fait" }
    },
    "completude": {
      "type": "object",
      "additionalProperties": { "type": "boolean" },
      "description": "Déclaration explicite de présence/absence par champ. Aucun champ absent ne doit être silencieux."
    }
  },
  "$defs": {
    "fait": {
      "type": "object",
      "required": ["champ", "valeur", "origine"],
      "properties": {
        "champ": { "type": "string" },
        "valeur": {},
        "origine": { "$ref": "#/$defs/origine" }
      }
    },
    "origine": {
      "type": "object",
      "required": ["source", "date_captee", "methode", "confiance"],
      "properties": {
        "source": { "type": "string" },
        "date_captee": { "type": "string", "format": "date" },
        "methode": { "type": "string", "enum": ["scraping", "manuel", "api"] },
        "confiance": { "type": "string", "enum": ["haute", "moyenne", "basse"] },
        "reference": { "type": "string", "format": "uri", "description": "URL ou identifiant de la source originale (traçabilité de provenance)" }
      }
    }
  }
}
